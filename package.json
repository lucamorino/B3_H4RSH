{
  "name": "harsher-noiser",
  "description": "soundworks application",
  "authors": [],
  "license": "BSD-3-Clause",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run clean && sass src/styles:.build/public/css && soundworks-build -b",
    "clean": "soundworks-build -D",
    "dev": "npm run build && (concurrently -i -p \"none\" \"npm run watch:inspect server\" \"soundworks-build -b -w\" \"npm run watch:sass\")",
    "lint": "npx eslint src",
    "start": "node .build/server/index.js",
    "watch": "soundworks-build -p",
    "watch:inspect": "soundworks-build -i -p",
    "watch:sass": "sass --watch src/styles:.build/public/css",
    "fetch-rnbo": "node scripts/fetch-rnbo.js"
  },
  "dependencies": {
    "@ircam/devicemotion": "^1.3.1",
    "@ircam/sc-components": "^3.3.3",
    "@ircam/sc-scheduling": "^1.0.0",
    "@rnbo/js": "^1.4.2",
    "@soundworks/core": "^5.4.1",
    "@soundworks/helpers": "^5.0.4",
    "@soundworks/max": "^1.1.1",
    "@soundworks/plugin-checkin": "^5.0.0",
    "@soundworks/plugin-filesystem": "^5.1.0",
    "@soundworks/plugin-platform-init": "^5.0.0",
    "@soundworks/plugin-scripting": "^5.0.4",
    "@soundworks/plugin-sync": "^5.0.0",
    "lit": "^3.1.3"
  },
  "devDependencies": {
    "@ircam/eslint-config": "^2.0.1",
    "@soundworks/build": "^5.2.4",
    "@soundworks/create": "^5.0.9",
    "@types/node": "^22.10.10",
    "@types/web": "^0.0.199",
    "concurrently": "^8.2.2",
    "eslint": "^9.18.0",
    "sass": "^1.77.1"
  },
  "main": "eslint.config.js",
  "keywords": [],
  "author": ""
}
